#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

. "${PWD}/.dev/utility.sh"

install_git_hooks() {
    if [[ -d "${ROOT_DIR}/.git" ]]; then
        rm -rf "${ROOT_DIR}/.git/hooks"
        ln -s ../.dev/git-hooks "${ROOT_DIR}/.git/hooks"
        chmod +x "${ROOT_DIR}/.dev/git-hooks"/* 2>/dev/null || true
    fi
}

install_git_hooks

case "${1:-}" in
    up:minimal)
        shift
        docker_compose up -d dev load-balancer "$@"
        ;;
    up:all)
        shift
        docker_compose --profile all up -d "$@"
        ;;
    down)
        shift
        docker_compose --profile all down "$@"
        ;;
    *)
        docker_compose "$@"
        ;;
esac
